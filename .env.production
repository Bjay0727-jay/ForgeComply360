# ForgeComply 360 - Production Configuration
# Cloudflare Workers deployment at comply360.forgecyberdefense.com

# Application
NODE_ENV=production
APP_NAME=ForgeComply 360
APP_VERSION=1.0.0
APP_URL=https://comply360.forgecyberdefense.com
API_URL=https://comply360-api.forgecyberdefense.com

# CORS - allowed origins for API requests
CORS_ORIGINS=https://comply360.forgecyberdefense.com,https://reporter-forgecomply360.pages.dev,https://reporter.forgecyberdefense.com

# JWT (set via wrangler secret, not in env file)
# JWT_SECRET=<set via: wrangler secret put JWT_SECRET>

# ForgeML AI Engine (optional)
# ANTHROPIC_API_KEY=<set via: wrangler secret put ANTHROPIC_API_KEY>

# Company branding
COMPANY_NAME=Forge Cyber Defense LLC
COMPANY_URL=https://www.forgecyberdefense.com
SUPPORT_EMAIL=support@forgecyberdefense.com
